<Window x:Class="Projekt.Forms.NoteEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteForge – Editor"
        Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Gornji dio – naslov i tip -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Label Content="Naslov:"/>
            <TextBox x:Name="txtTitle" Width="300" Margin="4,0"/>
            <Label Content="Tip:" Margin="8,0,0,0"/>
            <ComboBox x:Name="cmbType" Width="120" Margin="4,0">
                <ComboBoxItem>Personal</ComboBoxItem>
                <ComboBoxItem>Work</ComboBoxItem>
                <ComboBoxItem>Study</ComboBoxItem>
                <ComboBoxItem>Idea</ComboBoxItem>
                <ComboBoxItem>Project</ComboBoxItem>
            </ComboBox>
            <Label Content="Tagovi:" Margin="8,0,0,0"/>
            <TextBox x:Name="txtTags" Width="200" Margin="4,0"/>
        </StackPanel>

        <!-- Srednji dio – editor i preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lijevo: editor -->
            <DockPanel Grid.Column="0">
                <Label DockPanel.Dock="Top" Content="Markdown"/>
                <TextBox x:Name="txtEditor"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="Wrap"
                         TextChanged="txtEditor_TextChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Desno: preview -->
            <DockPanel Grid.Column="2">
                <Label DockPanel.Dock="Top" Content="Preview"/>
                <TextBox x:Name="txtPreview"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13"
                         TextWrapping="Wrap"
                         Background="#f5f5f5"/>
            </DockPanel>
        </Grid>

        <!-- Dno – gumbi -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="8">
            <Button x:Name="btnSave" Content="Spremi" 
                    Width="100" Margin="4" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Odustani" 
                    Width="100" Margin="4" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>